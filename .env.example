# ─────────────────────────────────────────────
# FinSight AI — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to Git
# ─────────────────────────────────────────────

# ── Data Source API Keys ──────────────────────
POLYGON_API_KEY=your_polygon_api_key_here
COINGECKO_API_KEY=your_coingecko_api_key_here      # optional — free tier works without key
NEWSAPI_API_KEY=your_newsapi_key_here

# ── OpenAI (Sentiment LLM) ───────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ── Azure Credentials ────────────────────────
AZURE_SUBSCRIPTION_ID=your_subscription_id
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_ID=your_service_principal_client_id
AZURE_CLIENT_SECRET=your_service_principal_secret
AZURE_RESOURCE_GROUP=finsight-rg

# ── Azure Storage (ADLS Gen2) ─────────────────
ADLS_ACCOUNT_NAME=finsightadls
ADLS_CONTAINER_NAME=finsight
ADLS_BRONZE_PATH=abfss://finsight@finsightadls.dfs.core.windows.net/bronze
ADLS_SILVER_PATH=abfss://finsight@finsightadls.dfs.core.windows.net/silver
ADLS_GOLD_PATH=abfss://finsight@finsightadls.dfs.core.windows.net/gold

# ── Databricks ────────────────────────────────
DATABRICKS_HOST=https://adb-XXXXXXXXXXXXXXXXX.X.azuredatabricks.net
DATABRICKS_TOKEN=your_databricks_personal_access_token
DATABRICKS_CLUSTER_ID=your_cluster_id
DATABRICKS_FEATURE_STORE_DB=finsight_features

# ── MLflow (Databricks managed) ──────────────
MLFLOW_TRACKING_URI=databricks
MLFLOW_EXPERIMENT_NAME=/finsight-ai/experiments

# ── FastAPI ───────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development                               # development | production

# ── Local Dev (no Azure) ─────────────────────
LOCAL_DATA_PATH=./data/local
USE_LOCAL_SPARK=true                              # set false when running on Databricks
